{
  "name": "patchworkfs",
  "displayName": "PatchworkFS",
  "description": "Edit automerge patchwork-filesystem folders in VS Code",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:automerge.openFolder",
    "onFileSystem:automerge",
    "workspaceContains:.vscode/settings.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "automerge.openFolder",
        "title": "PatchworkFS: Open Folder"
      },
      {
        "command": "automerge.restart",
        "title": "PatchworkFS: Restart"
      },
      {
        "command": "automerge.showStatus",
        "title": "PatchworkFS: Show Status"
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "package": "node build.mjs && vsce package --no-dependencies",
    "publish": "node build.mjs && vsce publish --no-dependencies",
    "login": "vsce login"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0",
    "vscode-languageclient": "^9.0.1"
  }
}
