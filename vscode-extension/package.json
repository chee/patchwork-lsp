{
  "name": "automerge-lsp-vscode",
  "displayName": "Automerge LSP",
  "description": "Edit automerge patchwork-filesystem folders in VS Code",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:automerge.openFolder",
    "onFileSystem:automerge",
    "workspaceContains:.vscode/settings.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "automerge.openFolder",
        "title": "Automerge: Open Folder"
      },
      {
        "command": "automerge.showStatus",
        "title": "Automerge: Show Status"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
